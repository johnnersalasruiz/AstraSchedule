# ─── Base de datos PostgreSQL ───────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=uniajc_horarios

# ─── Groq (agente IA) ────────────────────────────────────────────────────────
GROQ_API_KEY=tu_api_key_aqui

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS: origen del frontend (Vite dev server por defecto) ─────────────────
CORS_ORIGIN=http://localhost:5173
